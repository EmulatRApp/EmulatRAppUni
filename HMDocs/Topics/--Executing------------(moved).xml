  <title>Executing</title>
  <keywords>
    <keyword>--autosnapshot</keyword>
    <keyword>cold boot</keyword>
    <keyword>EMULATR_CONSOLE_MIRROR</keyword>
    <keyword>EMULATR_CONSOLE_PORT</keyword>
    <keyword>EMULATR_CONSOLE_SNAPSHOT</keyword>
    <keyword>EMULATR_FLASH_TRACE</keyword>
    <keyword>EMULATR_IDE_TRACE</keyword>
    <keyword>EMULATR_IIC_TRACE</keyword>
