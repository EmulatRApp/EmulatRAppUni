  <title>Snapshot Operations</title>
  <keywords>
    <keyword>.axpsnap</keyword>
    <keyword>autoload-newest</keyword>
    <keyword>--autosnapshot</keyword>
    <keyword>EMULATR_AUTOSNAP</keyword>
    <keyword>EMULATR_CONSOLE_SNAPSHOT</keyword>
    <keyword>EMULATR_NO_AUTOLOAD</keyword>
    <keyword>EMULATR_SNAPSHOT_MARKER</keyword>
    <keyword>EMULATR_SNAPSHOT_PRUNE</keyword>
    <keyword>--no-autoload</keyword>
