        </td>
        <td colspan="2">
          <para styleclass="Normal"><text styleclass="" style="font-family:Arial; font-size:10pt; font-weight:bold; color:#000000;">IRQ / DMA</text></para>
        </td>
      </thead>
      <tr style="vertical-align:top">
        <td>
          <para styleclass="Code Example">0</para>
        </td>
        <td>
          <para styleclass="Normal">Floppy (FDD)</para>
        </td>
        <td>
          <para styleclass="Normal"><text styleclass="Code Example">0x03F0</text></para>
        </td>
        <td colspan="2">
          <para styleclass="Normal">IRQ6 / DMA2 (Activate set)</para>
        </td>
      </tr>
      <tr style="vertical-align:top">
        <td>
          <para styleclass="Code Example">3</para>
        </td>
        <td>
          <para styleclass="Normal">Parallel (LPT1)</para>
        </td>
