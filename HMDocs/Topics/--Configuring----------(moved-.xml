        <td><para styleclass="Normal"><text style="font-weight:bold;">Example</text></para></td>
        <td><para styleclass="Normal"><text style="font-weight:bold;">CLI / Env override</text></para></td>
      </thead>
      <tr style="vertical-align:top">
