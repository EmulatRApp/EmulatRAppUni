      <thead style="vertical-align:top">
        <td><para styleclass="Normal"><text style="font-weight:bold;">Model</text></para></td>
        <td><para styleclass="Normal"><text style="font-weight:bold;">Capacity</text></para></td>
        <td><para styleclass="Normal"><text style="font-weight:bold;">Notes</text></para></td>
      </thead>
      <tr style="vertical-align:top"><td><para styleclass="Normal">RZ22</para></td><td><para styleclass="Normal">104 MB</para></td><td><para styleclass="Normal">SCSI drive</para></td></tr>
      <tr style="vertical-align:top"><td><para styleclass="Normal">RZ23</para></td><td><para styleclass="Normal">209 MB</para></td><td><para styleclass="Normal">SCSI drive</para></td></tr>
